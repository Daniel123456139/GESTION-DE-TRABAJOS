# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Shared Firestore collections (override if your shared DB uses other names)
VITE_FIREBASE_COLLECTION_USERS=USUARIOS
VITE_FIREBASE_COLLECTION_USERS_FALLBACKS=usuarios,USERS
VITE_FIREBASE_COLLECTION_EMPLOYEES=EMPLEADOS_REF
VITE_FIREBASE_COLLECTION_EMPLOYEES_FALLBACKS=EMPLEADOS
VITE_FIREBASE_COLLECTION_COMPETENCIAS=COMPETENCIAS
VITE_FIREBASE_COLLECTION_NOTAS=NOTAS
VITE_FIREBASE_COLLECTION_SICK_LEAVES=SICK_LEAVES
VITE_FIREBASE_COLLECTION_BAJAS=BAJAS
VITE_FIREBASE_COLLECTION_INCIDENT_LOG=INCIDENT_LOG
VITE_FIREBASE_COLLECTION_APP_GENERATED_PUNCHES=APP_GENERATED_PUNCHES
VITE_FIREBASE_COLLECTION_ACCESS_LOG=EMPLOYEE_ACCESS_LOG

# ERP API Configuration
VITE_API_BASE_URL=/api/erp
VITE_ERP_USERNAME=AppUser

# Local Storage Encryption (Optional but Recommended)
# If not provided, app derives a non-static fallback key
VITE_STORAGE_KEY=replace_with_random_long_value

# Gemini Client (INSEGURO - solo para desarrollo local)
# En producción usar proxy backend y NO exponer la clave en frontend
VITE_ALLOW_INSECURE_GEMINI_CLIENT=false
VITE_GEMINI_API_KEY=
