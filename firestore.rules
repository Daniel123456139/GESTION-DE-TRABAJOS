/**
 * Firestore Security Rules
 * 
 * PROPÓSITO:
 * - Proteger colecciones compartidas entre APP - PRESENCIA y APP - TALENTO
 * - Implementar control de acceso basado en roles
 * - Prevenir escritura de PII en Firestore
 * 
 * ROLES:
 * - hr: Recursos Humanos (lectura de datos)
 * - admin: Administrador (lectura y escritura)
 * - system: Sistema automatizado (solo para logs)
 * 
 * @version 2.0
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ═══════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════════════
    
    /**
     * Verificar si el usuario está autenticado
     */
    function isAuthenticated() {
      return request.auth != null;
    }
    
    /**
     * Verificar si el usuario tiene un rol específico
     */
    function currentRole() {
      return request.auth.token.rol != null ? request.auth.token.rol : request.auth.token.role;
    }

    function hasRole(role) {
      return isAuthenticated() && 
             currentRole() == role;
    }
    
    /**
     * Verificar si el usuario tiene al menos uno de los roles especificados
     */
    function hasAnyRole(roles) {
      return isAuthenticated() && 
             currentRole() in roles;
    }

    function hasHrOrAdminRole() {
      return hasAnyRole([
        'hr', 'HR', 'admin', 'ADMIN', 'RRHH', 'SUPER_ADMIN', 'super_admin'
      ]);
    }

    function hasAdminRole() {
      return hasAnyRole(['admin', 'ADMIN', 'SUPER_ADMIN', 'super_admin']);
    }
    
    /**
     * Validar que no se incluyan campos PII prohibidos
     * CRÍTICO PARA GDPR
     */
    function noPII() {
      let data = request.resource.data;
      return !('DescOperario' in data) &&
             !('nombre' in data) &&
             !('apellidos' in data) &&
             !('DNI' in data) &&
             !('NIF' in data) &&
             !('telefono' in data) &&
             !('email_personal' in data);
    }

    function validGeneratedPunchPayload() {
      let data = request.resource.data;
      return data.keys().hasOnly([
        'employeeId',
        'date',
        'time',
        'reasonId',
        'reasonDesc',
        'direction',
        'originalTime',
        'timeKey',
        'createdAt',
        'type'
      ]) &&
      data.employeeId is string &&
      data.employeeId.size() > 0 && data.employeeId.size() <= 6 &&
      data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
      data.time is string && data.time.matches('^\\d{2}:\\d{2}(:\\d{2})?$') &&
      (!('originalTime' in data) || (data.originalTime is string && data.originalTime.matches('^\\d{2}:\\d{2}(:\\d{2})?$'))) &&
      (!('timeKey' in data) || (data.timeKey is string && data.timeKey.matches('^\\d{2}:\\d{2}$'))) &&
      (!('reasonId' in data) || data.reasonId == null || data.reasonId is int) &&
      data.reasonDesc is string && data.reasonDesc.size() <= 120 &&
      data.direction in ['Entrada', 'Salida'] &&
      (!('type' in data) || data.type == 'synthetic_punch') &&
      (!('createdAt' in data) || data.createdAt is timestamp);
    }
    
    // ═══════════════════════════════════════════════════════════════
    // COLECCIÓN: USUARIOS / usuarios (Perfiles de login)
    // ═══════════════════════════════════════════════════════════════

    match /USUARIOS/{userId} {
      // El propio usuario puede leer su perfil, Admin también
      allow read: if isAuthenticated() && (request.auth.uid == userId || hasHrOrAdminRole());

      // Solo Admin puede crear/editar usuarios
      allow create, update, delete: if hasAdminRole();
    }

    match /usuarios/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || hasHrOrAdminRole());
      allow create, update, delete: if hasAdminRole();
    }

    // ═══════════════════════════════════════════════════════════════
    // COLECCIÓN: EMPLEADOS_REF (Datos compartidos con APP - TALENTO)
    // ═══════════════════════════════════════════════════════════════
    
    match /EMPLEADOS_REF/{employeeId} {
      // Lectura: HR y Admin
      allow read: if hasHrOrAdminRole();
      
      // Escritura: Solo Admin, con validación anti-PII
      allow create, update: if hasAnyRole(['admin', 'ADMIN', 'SUPER_ADMIN', 'super_admin']) && noPII();
      
      // Eliminación: Solo Admin
      allow delete: if hasAnyRole(['admin', 'ADMIN', 'SUPER_ADMIN', 'super_admin']);
    }
    
    // ═══════════════════════════════════════════════════════════════
    // COLECCIÓN: EMPLEADOS (Legacy - mantener por compatibilidad)
    // ═══════════════════════════════════════════════════════════════
    
    match /EMPLEADOS/{employeeId} {
      // Lectura: HR y Admin
      allow read: if hasHrOrAdminRole();
      
      // Escritura: Solo Admin, con validación anti-PII
      allow create, update: if hasAnyRole(['admin', 'ADMIN', 'SUPER_ADMIN', 'super_admin']) && noPII();
      
      // Eliminación: Solo Admin
      allow delete: if hasAnyRole(['admin', 'ADMIN', 'SUPER_ADMIN', 'super_admin']);
    }
    
    // ═══════════════════════════════════════════════════════════════
    // COLECCIÓN: COMPETENCIAS
    // ═══════════════════════════════════════════════════════════════
    
    match /COMPETENCIAS/{competenciaId} {
      // Lectura: HR y Admin
      allow read: if hasHrOrAdminRole();
      
      // Escritura: Solo Admin
      allow write: if hasAnyRole(['admin', 'ADMIN', 'SUPER_ADMIN', 'super_admin']);
    }
    
    // ═══════════════════════════════════════════════════════════════
    // COLECCIÓN: NOTAS
    // ═══════════════════════════════════════════════════════════════
    
    match /NOTAS/{notaId} {
      // Lectura: HR y Admin
      allow read: if hasHrOrAdminRole();
      
      // Creación: HR y Admin pueden crear notas
      allow create: if hasHrOrAdminRole() &&
                       request.resource.data.autor == request.auth.token.email;
      
      // Actualización/Eliminación: Solo el autor o Admin
      allow update, delete: if hasAnyRole(['admin', 'ADMIN', 'SUPER_ADMIN', 'super_admin']) || 
                               (isAuthenticated() && resource.data.autor == request.auth.token.email);
    }
    
    // ═══════════════════════════════════════════════════════════════
    // COLECCIÓN: EMPLOYEE_AUDIT_LOG (Historial de Cambios)
    // ═══════════════════════════════════════════════════════════════
    
    match /EMPLOYEE_AUDIT_LOG/{logId} {
      // Lectura: Solo Admin
      allow read: if hasAnyRole(['admin', 'ADMIN', 'SUPER_ADMIN', 'super_admin']);
      
      // Escritura: Solo Admin y Sistema
      allow create: if hasAnyRole(['admin', 'ADMIN', 'SUPER_ADMIN', 'super_admin', 'system', 'SYSTEM']);
      
      // NO permitir actualización ni eliminación (logs inmutables)
      allow update, delete: if false;
    }
    
    // ═══════════════════════════════════════════════════════════════
    // COLECCIÓN: EMPLOYEE_ACCESS_LOG (Registro de Accesos)
    // ═══════════════════════════════════════════════════════════════
    
    match /EMPLOYEE_ACCESS_LOG/{accessId} {
      // Lectura: Solo Admin
      allow read: if hasAnyRole(['admin', 'ADMIN', 'SUPER_ADMIN', 'super_admin']);
      
      // Creación: Cualquier usuario autenticado puede registrar su acceso
      allow create: if isAuthenticated() &&
                       request.resource.data.accessedBy == request.auth.token.email;
      
      // NO permitir actualización ni eliminación (logs inmutables)
      allow update, delete: if false;
    }
    
    // ═══════════════════════════════════════════════════════════════
    // COLECCIÓN: SICK_LEAVES (Bajas Médicas)
    // ═══════════════════════════════════════════════════════════════
    
    match /SICK_LEAVES/{leaveId} {
      // Lectura: HR y Admin
      allow read: if hasHrOrAdminRole();
      
      // Escritura: Solo HR y Admin
      allow write: if hasHrOrAdminRole();
    }

    // ═══════════════════════════════════════════════════════════════
    // COLECCIÓN: BAJAS (Histórico de Bajas Finalizadas)
    // ═══════════════════════════════════════════════════════════════
    
    match /BAJAS/{bajaId} {
      // Lectura: HR y Admin
      allow read: if hasHrOrAdminRole();

      // Escritura: Solo HR y Admin (para mover de activa a historico)
      allow write: if hasHrOrAdminRole();
    }
    
    // ═══════════════════════════════════════════════════════════════
    // COLECCIÓN: INCIDENT_LOG
    // ═══════════════════════════════════════════════════════════════
    
    match /INCIDENT_LOG/{incidentId} {
      // Lectura: HR y Admin
      allow read: if hasHrOrAdminRole();
      
      // Creación: HR y Admin
      allow create: if hasHrOrAdminRole();
      
      // NO permitir actualización ni eliminación (logs inmutables)
      allow update, delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════
    // COLECCIÓN: BAJAS_METADATA (Metadatos de bajas)
    // ═══════════════════════════════════════════════════════════════
    
    match /BAJAS_METADATA/{metadataId} {
      // Lectura: Solo HR y Admin
      allow read: if hasHrOrAdminRole();

      // Escritura: Solo HR y Admin
      allow write: if hasHrOrAdminRole();
    }

    // ═══════════════════════════════════════════════════════════════
    // COLECCIÓN: APP_GENERATED_PUNCHES
    // ═══════════════════════════════════════════════════════════════
    
    match /APP_GENERATED_PUNCHES/{punchId} {
      // Lectura: Solo HR/Admin por trazabilidad y protección de integridad
      allow read: if hasHrOrAdminRole();

      // Escritura: Solo HR/Admin con validación de payload
      allow create, update: if hasHrOrAdminRole() && validGeneratedPunchPayload();
      allow delete: if hasHrOrAdminRole();
    }
    
    // ═══════════════════════════════════════════════════════════════
    // REGLA POR DEFECTO: DENEGAR TODO LO DEMÁS
    // ═══════════════════════════════════════════════════════════════
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
